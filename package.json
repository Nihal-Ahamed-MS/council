{
  "name": "council",
  "version": "0.1.0",
  "description": "Broadcast a single prompt to multiple LLMs simultaneously, streamed side-by-side in the terminal.",
  "bin": {
    "council": "./dist/council.js"
  },
  "type": "module",
  "main": "dist/council.js",
  "files": [
    "dist/",
    "gateway/",
    "bin/"
  ],
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/council.js",
    "setup": "node dist/council.js setup",
    "dev": "tsx bin/council.js",
    "dev:setup": "tsx bin/council.js setup",
    "prepublishOnly": "npm run build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.1.0",
    "chalk": "^5.0.0",
    "dotenv": "^16.0.0",
    "ink": "^5.0.0",
    "inquirer": "^10.0.0",
    "openai": "^4.0.0",
    "ora": "^8.0.0",
    "react": "^18.0.0"
  }
}
